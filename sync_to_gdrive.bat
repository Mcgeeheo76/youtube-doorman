@echo off
chcp 65001 > nul
echo ========================================================
echo [%date% %time%] 구글 드라이브 1일 1회 백업 자동화 시작
echo ========================================================

:: 스크립트가 실행되는 위치의 상위 폴더(옵시디언 볼트 전체 루트)를 원본으로 설정
set "SOURCE_DIR=%~dp0.."
for %%I in ("%SOURCE_DIR%") do set "SOURCE_DIR_ABS=%%~fI"

:: 대상 경로 (구글 드라이브)
set "TARGET_DIR=G:\내 드라이브\01. CBF\00.26년\14.AX_ob"

echo.
echo 복사 원본: %SOURCE_DIR_ABS%
echo 복사 대상: %TARGET_DIR%
echo.

:: Robocopy 실행 (미러링 백업)
:: /MIR: 원본과 타겟을 완전 동일하게 미러링 (원본에 없는 파일은 타겟에서도 삭제됨)
:: /FFT: 클라우드 동기화 시 발생하는 타임스탬프 2초 단위 오류 보정
:: /Z: 복사 중단 시 재개 가능 모드
:: /W:5: 복사 실패 시 5초간 대기 후 다시 시도
:: /XA:H: 시스템 숨김 파일(desktop.ini 등) 동기화 오류 방지용 제외
:: /NP: 자잘한 백분율 표시 생략(로그 깔끔하게)
:: /MT:8: 다중 스레딩 지원으로 복사 속도 향상
robocopy "%SOURCE_DIR_ABS%" "%TARGET_DIR%" /MIR /FFT /Z /W:5 /XA:H /NP /MT:8

echo ========================================================
echo [%date% %time%] 구글 드라이브 동기화 백업 완료!
echo ========================================================
